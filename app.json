{
  "expo": {
    "version": "0.1.0-beta",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "name": "Music Player",
    "slug": "hifi-music-player",
    "extra": {
      "eas": {
        "projectId": "66cf61a2-a6eb-4a1d-8dd2-d4ca818e6248"
      }
    },
    "owner": "fushl",
    "android": {
      "package": "com.fushl.hifimusicplayer"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      "expo-font",
      "expo-image",
      "expo-router",
      "expo-web-browser"
    ],
    "ios": {
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    }
  }
}
